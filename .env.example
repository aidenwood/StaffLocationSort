# Google Maps API Key
# Get from: https://console.cloud.google.com/
# Required APIs: Maps JavaScript API, Places API, Directions API
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# Pipedrive API Configuration
# Get from: Pipedrive Settings > Personal Preferences > API
VITE_PIPEDRIVE_API_KEY=your_pipedrive_api_key_here

# Use live Pipedrive data instead of mock data (set to true for production)
VITE_USE_LIVE_DATA=false